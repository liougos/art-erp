# Copy this file to .env and fill in your values
# cp .env.example .env

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# PostgreSQL (used in Docker / production)
POSTGRES_DB=art_erp
POSTGRES_USER=art_erp
POSTGRES_PASSWORD=change-me-strong-password

# For local dev without Docker, SQLite is used automatically.
# To use PostgreSQL locally, set:
# DATABASE_URL=postgresql://art_erp:password@localhost:5432/art_erp

# Flask environment: development | production
FLASK_ENV=development

# Anthropic API key for AI Legal Chat
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Drive integration (optional)
# 1. Go to console.cloud.google.com → Create project → Enable Drive API
# 2. IAM → Service Accounts → Create → Download JSON key
# 3. Share your Drive folder with the service account email
# 4. Copy the folder ID from the Drive URL
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-folder-id
